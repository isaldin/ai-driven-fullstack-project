# Managed by Ansible ({{ ansible_managed }}) — do not edit on the server.
# Rendered from group_vars/all.yml + the encrypted vault.

NODE_ENV={{ node_env }}
# Compose deployment: @app/config rejects localhost in DB/Redis/CORS/cookie in prod.
DEPLOYMENT_MODE={{ deployment_mode }}

# Database
DATABASE_URL={{ vault_database_url }}
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ vault_postgres_password }}
POSTGRES_DB={{ postgres_db }}
POSTGRES_PORT={{ postgres_port }}

# Auth (refresh tokens are opaque + DB-hashed; there is no refresh signing secret)
JWT_ACCESS_SECRET={{ vault_jwt_access_secret }}
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Backend HTTP
BACKEND_PORT={{ backend_port }}
FRONTEND_PORT={{ frontend_port }}
CORS_ORIGIN={{ cors_origin }}
COOKIE_DOMAIN={{ cookie_domain }}

# Service-to-service
SERVICE_API_TOKEN={{ vault_service_api_token }}

# Telegram bot
TELEGRAM_BOT_TOKEN={{ vault_telegram_bot_token }}
BACKEND_URL={{ backend_url }}

# Redis
REDIS_URL={{ vault_redis_url }}
REDIS_PORT={{ redis_port }}

# Observability
LOG_LEVEL={{ log_level }}
OTEL_SERVICE_NAME={{ otel_service_name }}
OTEL_SDK_DISABLED={{ otel_sdk_disabled }}
OTEL_EXPORTER_OTLP_ENDPOINT={{ otel_exporter_otlp_endpoint }}
OTEL_EXPORTER_OTLP_HEADERS={{ otel_exporter_otlp_headers }}
METRICS_EXPORTER={{ metrics_exporter }}
SENTRY_DSN={{ vault_sentry_dsn }}

# Immutable image digests (pulled, never built on the VPS)
BACKEND_IMAGE={{ backend_image }}
FRONTEND_IMAGE={{ frontend_image }}
BOT_IMAGE={{ bot_image }}

# Reverse proxy / TLS (Caddy edge profile)
APP_DOMAIN={{ app_domain }}
API_DOMAIN={{ api_domain }}
OBSERVE_DOMAIN={{ observe_domain }}
ACME_EMAIL={{ acme_email }}
ENABLE_BROWSER_OTLP={{ enable_browser_otlp }}

# Frontend (baked at build time)
VITE_API_URL={{ vite_api_url }}

# OpenObserve (observability profile)
ZO_ROOT_USER_EMAIL={{ vault_openobserve_email }}
ZO_ROOT_USER_PASSWORD={{ vault_openobserve_password }}
# Collector -> OpenObserve auth: Basic base64(email:password). Derived from the vault creds above so it
# always matches (the compose default only encodes the ChangeMe123! placeholder).
OPENOBSERVE_AUTH_HEADER=Basic {{ (vault_openobserve_email ~ ':' ~ vault_openobserve_password) | b64encode }}
