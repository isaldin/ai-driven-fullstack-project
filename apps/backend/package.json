{
  "name": "@app/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "db:generate": "zen generate --schema src/zenstack/schema.zmodel",
    "db:migrate": "zen migrate deploy --schema src/zenstack/schema.zmodel",
    "db:smoke": "node --env-file-if-exists=../../.env --import @swc-node/register/esm-register src/zenstack/migration-smoke.ts",
    "db:migrate:dev": "node ../../scripts/with-env.mjs zen migrate dev --schema src/zenstack/schema.zmodel",
    "db:push": "node ../../scripts/with-env.mjs zen db push --schema src/zenstack/schema.zmodel",
    "bootstrap-admin": "node --env-file-if-exists=../../.env --import @swc-node/register/esm-register src/zenstack/bootstrap-admin.ts",
    "db:seed": "pnpm bootstrap-admin",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "start": "node --env-file-if-exists=../../.env dist/main.js",
    "dev": "node --env-file-if-exists=../../.env --watch --import @swc-node/register/esm-register src/main.ts"
  },
  "dependencies": {
    "@app/config": "workspace:*",
    "@app/contracts": "workspace:*",
    "@app/observability": "workspace:*",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "1.9.1",
    "@zenstackhq/orm": "3.8.2",
    "@zenstackhq/schema": "3.8.2",
    "argon2": "0.44.0",
    "cookie-parser": "1.4.7",
    "helmet": "^8.2.0",
    "nestjs-pino": "4.6.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@app/tsconfig": "workspace:*",
    "@nestjs/testing": "11.1.27",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.43",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/passport-jwt": "4.0.1",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "@zenstackhq/cli": "3.8.2",
    "supertest": "7.2.2",
    "typescript": "7.0.2",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.10"
  }
}
