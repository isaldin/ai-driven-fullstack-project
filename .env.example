# ─────────────────────────────────────────────────────────────
# Environment contract — validated at startup by @app/config (Zod)
# Copy to .env and fill in. Never commit the real .env.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development

# Database (ZenStack v3 / pg)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# Auth
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Backend HTTP
BACKEND_PORT=3000
CORS_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=localhost

# Service-to-service (Telegram bot -> backend)
SERVICE_API_TOKEN=change-me-service-token

# Telegram bot
TELEGRAM_BOT_TOKEN=000000:replace-with-botfather-token
BACKEND_URL=http://localhost:3000

# Redis (bot sessions / shared infra)
REDIS_URL=redis://localhost:6379
# Optional: enable Redis auth in Docker Compose. If set, the redis service starts
# with --requirepass and you MUST embed it in REDIS_URL: redis://:<password>@redis:6379
REDIS_PASSWORD=

# Observability (OpenTelemetry -> OpenObserve by default)
LOG_LEVEL=debug
OTEL_SERVICE_NAME=app
OTEL_SDK_DISABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:5080/api/default
OTEL_EXPORTER_OTLP_HEADERS=
METRICS_EXPORTER=otlp

# Error tracking (optional)
SENTRY_DSN=

# Frontend (Vite)
VITE_API_URL=http://localhost:3000
