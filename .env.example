# ─────────────────────────────────────────────────────────────
# Environment contract — validated at startup by @app/config (Zod)
# Copy to .env and fill in. Never commit the real .env.
#
# The values below are HOST-oriented placeholders for local `pnpm dev` only. In
# production (NODE_ENV=production) @app/config REJECTS every placeholder/known
# default here — see packages/config/src/index.ts. Generate real secrets with a
# CSPRNG, e.g.:
#     openssl rand -base64 48        # JWT_ACCESS_SECRET / SERVICE_API_TOKEN (>=32 chars)
#     openssl rand -hex 32           # equivalent, hex encoding
# Never reuse one secret for two variables — the validator rejects duplicates.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
# Deployment shape. `standalone` for local/bare-metal; the Ansible deploy sets
# `compose`, which (in production) forbids localhost in DB/Redis/CORS/cookie.
DEPLOYMENT_MODE=standalone

# Database (ZenStack v3 / pg) — must be a postgres:// or postgresql:// URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# Auth. Access tokens are JWTs signed with JWT_ACCESS_SECRET. Refresh tokens are
# OPAQUE random strings hashed in the DB (no signing secret) — there is no
# JWT_REFRESH_SECRET. Production requires >=32 random chars here.
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Backend HTTP. CORS_ORIGIN must be https:// in production (no wildcard with
# credentials); COOKIE_DOMAIN must be your real domain, not localhost.
BACKEND_PORT=3000
CORS_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=localhost

# Service-to-service (Telegram bot -> backend). >=32 random chars in production.
SERVICE_API_TOKEN=change-me-service-token

# Telegram bot
TELEGRAM_BOT_TOKEN=000000:replace-with-botfather-token
BACKEND_URL=http://localhost:3000

# Redis (bot sessions / shared infra)
REDIS_URL=redis://localhost:6379
# Optional: enable Redis auth in Docker Compose. If set, the redis service starts
# with --requirepass and you MUST embed it in REDIS_URL: redis://:<password>@redis:6379
REDIS_PASSWORD=

# Observability (OpenTelemetry -> Collector -> OpenObserve). OFF by default; to enable,
# set OTEL_SDK_DISABLED=false and start the `observability` Compose profile. See docs/OBSERVABILITY.md.
# `info` keeps logs clean (app logs + warnings/errors); `debug` adds per-request access logs
# (with all req/res headers) and other verbose detail.
LOG_LEVEL=info
# For host `pnpm dev`. The Docker Compose stack overrides this per service (app-backend /
# app-telegram-bot) so services stay distinct in traces — don't set a single shared name there.
OTEL_SERVICE_NAME=app
# Set to your release tag/SHA — emitted as the service.version resource attribute.
SERVICE_VERSION=0.0.0
OTEL_SDK_DISABLED=true
# Traces + metrics are pushed here. LEAVE EMPTY for the Docker Compose stack: Compose fills in the
# collector address (otel-collector:4318) via `${...:-default}`, and a value here would OVERRIDE that
# default (Compose interpolates .env under the required `--env-file .env`) — pointing the app at the
# wrong host (inside the backend container `localhost:4318` is the container itself, not the collector).
# For host `pnpm dev`, set it to the collector's published port: http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
# App -> collector needs no auth (the collector holds the OpenObserve credentials).
OTEL_EXPORTER_OTLP_HEADERS=
METRICS_EXPORTER=otlp
# Verbose traces/logs are OFF by default so signal isn't buried in noise:
#   OTEL_VERBOSE_SPANS=true  -> keep per-middleware Express spans (~20 spans/request vs ~2).
#   LOG_LEVEL=debug          -> show the per-request access logs (with all req/res headers);
#                               at the default `info` they're hidden, but 4xx/5xx still log.
OTEL_VERBOSE_SPANS=false
# Head sampling (production): the OTel NodeSDK reads these standard env vars directly (no code change).
# Keep 100% locally; sample ordinary traffic in prod. Errors/slow traces are better kept via the
# collector's tail_sampling — see docs/OBSERVABILITY.md §11.
#   OTEL_TRACES_SAMPLER=parentbased_traceidratio
#   OTEL_TRACES_SAMPLER_ARG=0.1
# The collector authenticates to OpenObserve with this header —
# base64("<ZO_ROOT_USER_EMAIL>:<ZO_ROOT_USER_PASSWORD>"). Default matches the Compose
# defaults (admin@example.com / ChangeMe123!); regenerate if you change them:
#   printf '%s' 'admin@example.com:ChangeMe123!' | base64
OPENOBSERVE_AUTH_HEADER=Basic YWRtaW5AZXhhbXBsZS5jb206Q2hhbmdlTWUxMjMh
# OpenObserve root login + host ports (only used with the `observability` profile). These have working
# Compose defaults; uncomment to change. If you change the creds, also regenerate OPENOBSERVE_AUTH_HEADER
# above (printf '%s' 'EMAIL:PASSWORD' | base64).
#   ZO_ROOT_USER_EMAIL=admin@example.com
#   ZO_ROOT_USER_PASSWORD=ChangeMe123!
#   OPENOBSERVE_PORT=5080
#   OTEL_COLLECTOR_PORT=4318

# Error tracking (optional). Backend server errors are recorded on the trace span
# (recordException) and in structured logs; this DSN is reserved for optional backend Sentry.
SENTRY_DSN=

# Reverse proxy / TLS (production Caddy edge — only used with `--profile edge`).
# Set these to your real domains and an ACME contact email before deploying.
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
OBSERVE_DOMAIN=observe.example.com
ACME_EMAIL=admin@example.com
# Set to "true" only if you enable browser (RUM) tracing; exposes a locked-down
# /otlp ingest path via Caddy. Leave empty to keep the collector fully internal.
ENABLE_BROWSER_OTLP=

# Frontend (Vite)
VITE_API_URL=http://localhost:3000
# Frontend error tracking (Sentry) — OFF by default (empty DSN). Captures JS errors, Session
# Replay and Web Vitals. It is NOT a second tracer: OTel above owns the distributed trace, and
# each Sentry event is stamped with the active trace_id so you can jump from an issue to the full
# frontend→backend trace. VITE_SENTRY_REPLAY_SAMPLE_RATE is the share (0..1) of sessions to
# replay; error sessions are always replayed.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_RELEASE=
VITE_SENTRY_REPLAY_SAMPLE_RATE=0
# Browser (RUM) tracing — OFF by default (empty). Set to the collector's browser-reachable
# OTLP/HTTP endpoint to trace from the browser: fetch calls get a client span AND a W3C
# `traceparent` header, so the backend span becomes a child — one end-to-end trace.
# The browser runs on the host, so use the collector's published port (not the compose name):
#   VITE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=
VITE_OTEL_SERVICE_NAME=app-frontend
